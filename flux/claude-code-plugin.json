{
  "name": "flux",
  "description": "Injects sidecar-generated stray thoughts into Claude Code sessions through hooks.",
  "version": "0.1.0",
  "hooks": {
    "Stop": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/flux-hook-wrapper.mjs\" --host=claude-code",
    "PostToolUse": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/flux-hook-wrapper.mjs\" --host=claude-code"
  },
  "configuration": ".flux/config.json"
}
