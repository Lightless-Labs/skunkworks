{
  "name": "flux",
  "description": "Injects sidecar-generated stray thoughts into Claude Code sessions through hooks.",
  "version": "0.1.0",
  "hooks": {
    "Stop": "node ./dist/src/adapters/claude-code/hook.js --host=claude-code",
    "PostToolUse": "node ./dist/src/adapters/claude-code/hook.js --host=claude-code"
  },
  "configuration": ".flux/config.json"
}
