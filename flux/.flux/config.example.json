{
  "enabled": true,
  "randomInjections": true,
  "delivery": "steer",
  "displayThoughts": true,
  "triggerTurn": true,
  "context": {
    "maxUserMessages": 4,
    "maxAssistantMessages": 4,
    "maxToolEvents": 12,
    "maxChars": 18000
  },
  "models": [
    {
      "name": "cheap-openai-compatible",
      "provider": "openai-compatible",
      "model": "gpt-4.1-mini",
      "baseUrl": "https://api.openai.com/v1",
      "apiKeyEnv": "OPENAI_API_KEY",
      "temperature": 0.9,
      "maxTokens": 420
    },
    {
      "name": "anthropic-haiku",
      "provider": "anthropic",
      "model": "claude-3-5-haiku-latest",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "temperature": 0.8,
      "maxTokens": 420
    }
  ],
  "triggers": [
    {
      "name": "random-turn-end",
      "kind": "random",
      "enabled": true,
      "probability": 0.18,
      "minIntervalMs": 180000,
      "afterEvents": 2
    },
    {
      "name": "loop-language",
      "kind": "loop-detected",
      "enabled": true,
      "probability": 1,
      "minIntervalMs": 60000,
      "patterns": ["again", "still failing", "same error", "loop", "stuck", "retry"]
    }
  ],
  "prompt": {
    "system": "You are Flux, an ADHD-brain sidecar for a coding agent. Generate one concise stray thought that may help the main agent escape tunnel vision. Be specific, creative, and useful. Output only the stray thought text.",
    "style": "Keep the thought under 120 words. Prefer overlooked constraints, alternative hypotheses, cheap checks, or reframes."
  },
  "storage": {
    "thoughtLog": ".flux/thoughts.jsonl"
  }
}
