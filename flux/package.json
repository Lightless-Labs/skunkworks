{
  "name": "@lightless-labs/flux",
  "version": "0.1.0",
  "description": "Stray-thought sidecar for Claude Code, Codex, and pi agents.",
  "type": "module",
  "private": true,
  "keywords": ["pi-package", "claude-code-plugin", "codex-plugin", "agent-hooks", "creativity"],
  "license": "MIT",
  "bin": {
    "flux-hook": "./dist/bin/flux-hook.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./pi": "./src/adapters/pi/index.ts",
    "./claude-code-hook": "./dist/src/adapters/claude-code/hook.js",
    "./codex-hook": "./dist/src/adapters/codex/hook.js"
  },
  "pi": {
    "extensions": ["./src/adapters/pi/index.ts"]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start:hook": "node ./dist/bin/flux-hook.js",
    "dev:pi": "pi -e ./src/adapters/pi/index.ts",
    "test:dry-run": "node --test ./test/*.test.js"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
