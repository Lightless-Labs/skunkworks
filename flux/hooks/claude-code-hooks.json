{
  "description": "Flux Claude Code hooks. Runs through a safe-fail wrapper that can install/build from a git checkout on first use.",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/flux-hook-wrapper.mjs\" --host=claude-code"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/flux-hook-wrapper.mjs\" --host=claude-code"
          }
        ]
      }
    ]
  }
}
