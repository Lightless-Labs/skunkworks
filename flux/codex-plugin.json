{
  "name": "flux",
  "description": "Sidecar stray-thought generator for Codex hook-capable runtimes.",
  "version": "0.1.0",
  "hooks": {
    "Stop": "node \"${PLUGIN_ROOT}/scripts/flux-hook-wrapper.mjs\" --host=codex",
    "PostToolUse": "node \"${PLUGIN_ROOT}/scripts/flux-hook-wrapper.mjs\" --host=codex"
  },
  "configuration": ".flux/config.json"
}
